# Application
APP_NAME=financial-notification-platform
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=financial_notifications
POSTGRES_USER=fnp_user
POSTGRES_PASSWORD=fnp_secure_password_change_me
DATABASE_URL=postgresql+asyncpg://fnp_user:fnp_secure_password_change_me@postgres:5432/financial_notifications
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0
REDIS_URL=redis://:redis_secure_password_change_me@redis:6379/0
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT_TTL=86400

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=fnp_user
RABBITMQ_PASSWORD=fnp_rabbit_password_change_me
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://fnp_user:fnp_rabbit_password_change_me@rabbitmq:5672/

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP_ID=fnp-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000
KAFKA_MAX_POLL_RECORDS=500

# Kafka Topics
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification.events
KAFKA_TOPIC_NOTIFICATION_STATUS=notification.status
KAFKA_TOPIC_DLQ=notification.dlq
KAFKA_TOPIC_ANALYTICS=notification.analytics
KAFKA_TOPIC_RETRY=notification.retry

# Celery
CELERY_BROKER_URL=redis://:redis_secure_password_change_me@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_password_change_me@redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Asia/Kolkata
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=60

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourfinancialapp.com
SENDGRID_FROM_NAME=Financial Notifications
SENDGRID_SANDBOX_MODE=false

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Notification Settings
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,hi
QUIET_HOURS_START=22
QUIET_HOURS_END=8
QUIET_HOURS_TIMEZONE=Asia/Kolkata
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60
FREQUENCY_CAP_HOURLY=10
FREQUENCY_CAP_DAILY=50
FREQUENCY_CAP_WEEKLY=200

# TRAI DND
TRAI_DND_CHECK_ENABLED=true
TRAI_DND_API_URL=https://trai-dnd-api.example.com
TRAI_DND_API_KEY=your_trai_api_key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/fnp/app.log

# Admin
ADMIN_EMAIL=admin@yourfinancialapp.com
ADMIN_PASSWORD=change_me_immediately
FIRST_SUPERUSER_EMAIL=superadmin@yourfinancialapp.com
FIRST_SUPERUSER_PASSWORD=change_me_immediately_superadmin
